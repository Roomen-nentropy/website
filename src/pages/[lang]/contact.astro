---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AssetImage from '../../components/AssetImage.astro';
import { contacts } from '../../i18n/contacts';
import { brandAssets } from '../../i18n/assets';
import { t } from '../../i18n/ui';
import type { Lang } from '../../i18n/types';

export function getStaticPaths() {
  return [{ params: { lang: 'bg' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const strings = t(lang);
const focus = Astro.url.searchParams.get('focus');
const allContacts = contacts[lang];
const visibleContacts = focus === 'rumen' ? allContacts.filter((c) => c.focus === 'rumen') : allContacts;
const brochureUrl = 'https://roomen-nentropy.github.io/nentropy_brochure_ifsfocusdays/';
const demoSubject = lang === 'bg' ? 'Заявка за демонстрация — Nentropy' : 'Demo request — Nentropy';
---

<BaseLayout lang={lang} title={`${strings.contact.title} | Nentropy`} description={strings.contact.subtitle} currentPath={Astro.url.pathname}>
  <section class="section-pad">
    <div class="mx-auto grid max-w-6xl items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="section-label">{strings.nav.contact}</p>
        <h1 class="mt-3 text-4xl font-bold text-purple-deep sm:text-5xl">{strings.contact.title}</h1>
        <p class="mt-4 text-lg leading-relaxed text-ink/70">{strings.contact.subtitle}</p>
        {focus === 'rumen' && (
          <p class="mt-3 text-sm font-medium text-phoenix-ember">{strings.contact.rumenOnly}</p>
        )}
        <p class="mt-6 text-sm text-ink/60">
          <a href={brochureUrl} class="font-semibold text-purple-mid hover:text-phoenix-ember" target="_blank" rel="noopener">
            {strings.contact.brochureLink} →
          </a>
        </p>
      </div>
      <div class="art-frame hidden max-w-sm lg:flex">
        <AssetImage src={brandAssets.talisman.handshake} alt="" width={320} height={320} />
      </div>
    </div>
  </section>

  <section id="consultation" class="mx-auto max-w-4xl px-4 pb-24 sm:px-6 lg:px-8">
    <div class={`grid gap-6 ${visibleContacts.length > 1 ? 'sm:grid-cols-2' : 'max-w-md mx-auto'}`}>
      {visibleContacts.map((person) => (
        <div class="card-surface flex flex-col">
          <h2 class="text-xl font-bold text-purple-deep">{person.name}</h2>
          <p class="mt-1 text-sm text-steel">{person.role}</p>
          <a href={`mailto:${person.email}`} class="mt-4 text-sm font-medium text-purple-mid hover:text-phoenix-ember break-all">
            {person.email}
          </a>
          {person.phone && (
            <a href={`tel:${person.phone.replace(/\s/g, '')}`} class="mt-2 text-sm text-ink/70 hover:text-purple-deep">
              {person.phone}
            </a>
          )}
          <a
            href={`mailto:${person.email}?subject=${encodeURIComponent(demoSubject)}`}
            class="btn-phoenix mt-6 text-center text-sm"
          >
            {strings.cta.demo}
          </a>
        </div>
      ))}
    </div>
  </section>
</BaseLayout>
