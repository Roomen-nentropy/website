---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { t, langPath } from '../../../../i18n/ui';
import type { Lang } from '../../../../i18n/types';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return ['bg', 'en'].flatMap((lang) =>
    docs.map((doc) => ({
      params: { lang, slug: doc.slug },
      props: { doc },
    }))
  );
}

const { doc } = Astro.props;
const lang = Astro.params.lang as Lang;
const strings = t(lang);
const { Content } = await doc.render();

const allDocs = (await getCollection('docs'))
  .filter((d) => d.data.section === 'integrations')
  .sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout lang={lang} title={`${doc.data.title} | Nentropy`} description={doc.data.description ?? doc.data.title} currentPath={Astro.url.pathname}>
  <div class="mx-auto flex max-w-7xl flex-col gap-12 px-4 py-16 lg:flex-row lg:px-8">
    <aside class="lg:w-64 shrink-0">
      <nav class="sticky top-24 space-y-1">
        {allDocs.map((d) => (
          <a
            href={langPath(lang, `/docs/integrations/${d.slug}`)}
            class:list={[
              'block rounded-lg px-3 py-2 text-sm font-medium',
              d.slug === doc.slug ? 'bg-purple-deep/10 text-purple-deep' : 'text-ink/80 hover:bg-white/80',
            ]}
          >
            {d.data.title}
          </a>
        ))}
      </nav>
    </aside>
    <article class="prose-nentropy min-w-0 flex-1">
      <h1>{doc.data.title}</h1>
      <Content />
    </article>
  </div>
</BaseLayout>
