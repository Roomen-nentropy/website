---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { t } from '../../../i18n/ui';
import { assetUrl } from '../../../i18n/paths';
import type { Lang } from '../../../i18n/types';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts
    .filter((p) => !p.data.draft)
    .map((post) => ({
      params: { lang: post.data.locale, slug: post.slug },
      props: { post },
    }));
}

const { post } = Astro.props;
const lang = Astro.params.lang as Lang;
const strings = t(lang);
const { Content } = await post.render();
const pdfUrl = post.data.pdf ? assetUrl(post.data.pdf) : undefined;
---

<BaseLayout lang={lang} title={`${post.data.title} | Nentropy`} description={post.data.description} currentPath={Astro.url.pathname}>
  <article class="mx-auto max-w-3xl px-4 py-16 sm:px-6 lg:px-8">
    <header>
      <time class="text-sm text-steel" datetime={post.data.date.toISOString()}>
        {post.data.date.toLocaleDateString(lang === 'bg' ? 'bg-BG' : 'en-GB')}
      </time>
      <h1 class="mt-4 text-4xl font-bold text-purple-deep">{post.data.title}</h1>
      <p class="mt-4 text-lg text-ink/70">{post.data.description}</p>
      {post.data.author && <p class="mt-2 text-sm text-steel">{post.data.author}</p>}
    </header>

    {pdfUrl && (
      <div class="mt-10 rounded-2xl border border-purple-mid/20 bg-white/80 p-4">
        <p class="text-sm font-semibold text-purple-deep mb-4">{strings.blog.downloadPdf}</p>
        <iframe src={pdfUrl} class="w-full h-[70vh] rounded-xl border border-ink/10" title={post.data.title}></iframe>
        <a href={pdfUrl} class="btn-secondary mt-4 inline-flex" download>{strings.blog.downloadPdf}</a>
      </div>
    )}

    <div class="prose-nentropy mt-10">
      <Content />
    </div>
  </article>
</BaseLayout>
