---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { t, langPath } from '../../../i18n/ui';
import AssetImage from '../../../components/AssetImage.astro';
import type { Lang } from '../../../i18n/types';

export function getStaticPaths() {
  return [{ params: { lang: 'bg' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const strings = t(lang);

const posts = (await getCollection('blog'))
  .filter((p) => p.data.locale === lang && !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout lang={lang} title={`${strings.blog.title} | Nentropy`} description={strings.blog.title} currentPath={Astro.url.pathname}>
  <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
    <h1 class="text-4xl font-bold text-purple-deep">{strings.blog.title}</h1>
    <div class="mt-12 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => (
        <article class="card-surface flex flex-col">
          {post.data.coverImage && (
            <AssetImage src={post.data.coverImage} alt="" class="mb-4 -mx-2 -mt-2 w-[calc(100%+1rem)] rounded-t-2xl object-cover h-40" />
          )}
          <time class="text-xs font-medium text-steel" datetime={post.data.date.toISOString()}>
            {post.data.date.toLocaleDateString(lang === 'bg' ? 'bg-BG' : 'en-GB')}
          </time>
          <h2 class="mt-2 text-lg font-bold text-purple-deep">
            <a href={langPath(lang, `/blog/${post.slug}`)} class="hover:text-phoenix-ember">{post.data.title}</a>
          </h2>
          <p class="mt-2 flex-1 text-sm text-ink/70">{post.data.description}</p>
          {post.data.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="rounded-full bg-purple-deep/5 px-2 py-0.5 text-xs text-purple-mid">{tag}</span>
              ))}
            </div>
          )}
          <a href={langPath(lang, `/blog/${post.slug}`)} class="mt-4 text-sm font-semibold text-purple-mid hover:text-phoenix-ember">
            {strings.blog.readMore} →
          </a>
        </article>
      ))}
    </div>
    {posts.length === 0 && (
      <p class="mt-8 text-ink/60">{lang === 'bg' ? 'Скоро първи публикации.' : 'First publications coming soon.'}</p>
    )}
  </section>
</BaseLayout>
