---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionReveal from '../../components/SectionReveal.astro';
import SolutionCard from '../../components/SolutionCard.astro';
import ConsultationCTA from '../../components/ConsultationCTA.astro';
import { solutionGateway } from '../../i18n/solutions';
import { t, langPath } from '../../i18n/ui';
import type { Lang } from '../../i18n/types';

export function getStaticPaths() {
  return [{ params: { lang: 'bg' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const strings = t(lang);
const currentPath = Astro.url.pathname;

const pageTitle = lang === 'bg'
  ? 'Nentropy — Съответствие във веригата на доставки'
  : 'Nentropy — Supply chain compliance platform';
const pageDesc = strings.home.heroSubtitle;
---

<BaseLayout lang={lang} title={pageTitle} description={pageDesc} currentPath={currentPath}>
  <section class="relative overflow-hidden px-4 py-20 sm:px-6 lg:px-8 lg:py-28">
    <div class="pointer-events-none absolute -right-32 -top-32 h-96 w-96 rounded-full bg-phoenix-flame/10 blur-3xl"></div>
    <div class="pointer-events-none absolute -left-24 bottom-0 h-80 w-80 rounded-full bg-purple-mid/15 blur-3xl"></div>
    <div class="relative mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="text-sm font-semibold uppercase tracking-widest text-phoenix-ember">{strings.tagline}</p>
        <h1 class="mt-4 text-4xl font-bold leading-tight tracking-tight sm:text-5xl lg:text-6xl">
          <span class="gradient-text">{strings.home.heroTitle}</span>
        </h1>
        <p class="mt-6 max-w-xl text-lg text-ink/75 leading-relaxed">{strings.home.heroSubtitle}</p>
        <div class="mt-10 flex flex-wrap gap-4">
          <ConsultationCTA lang={lang} variant="phoenix" />
          <a href="https://app.joinnentropy.com/auth" class="btn-secondary">{strings.cta.trial}</a>
        </div>
        <p class="mt-4 text-xs text-ink/50">{lang === 'bg' ? '7 дни безплатен пробен период · Без кредитна карта' : '7-day free trial · No credit card required'}</p>
      </div>
      <div class="relative">
        <div class="grid grid-cols-2 gap-4">
          <figure class="card-surface !p-4">
            <img src="/assets/talisman-burdened.svg" alt="" class="w-full rounded-xl" width="280" height="220" />
            <figcaption class="mt-2 text-center text-xs font-medium text-ink/60">
              {lang === 'bg' ? 'Преди: ръчни задачи' : 'Before: manual overload'}
            </figcaption>
          </figure>
          <figure class="card-surface !p-4 mt-8">
            <img src="/assets/talisman-calm.svg" alt="" class="w-full rounded-xl" width="280" height="220" />
            <figcaption class="mt-2 text-center text-xs font-medium text-purple-deep">
              {lang === 'bg' ? 'С Nentropy' : 'With Nentropy'}
            </figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <SectionReveal>
    <section id="solutions" class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="text-center">
        <h2 class="text-3xl font-bold text-purple-deep">{strings.home.solutionsTitle}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-ink/70">{strings.home.solutionsSubtitle}</p>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {solutionGateway.map((s) => {
          const copy = lang === 'bg' ? s.bg : s.en;
          return (
            <SolutionCard lang={lang} slug={s.slug} icon={s.icon} title={copy.title} short={copy.short} />
          );
        })}
      </div>
    </section>
  </SectionReveal>

  <SectionReveal>
    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <h2 class="text-center text-3xl font-bold text-purple-deep">{strings.home.howTitle}</h2>
      <div class="mt-12 grid gap-8 md:grid-cols-3">
        {[
          { n: '1', title: strings.home.step1Title, desc: strings.home.step1Desc, color: 'border-phoenix-flame' },
          { n: '2', title: strings.home.step2Title, desc: strings.home.step2Desc, color: 'border-purple-mid' },
          { n: '3', title: strings.home.step3Title, desc: strings.home.step3Desc, color: 'border-steel' },
        ].map((step) => (
          <div class={`card-surface border-t-4 ${step.color}`}>
            <span class="text-3xl font-bold text-purple-deep/30">{step.n}</span>
            <h3 class="mt-4 text-lg font-bold text-purple-deep">{step.title}</h3>
            <p class="mt-2 text-sm text-ink/70">{step.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </SectionReveal>

  <SectionReveal>
    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2">
        <img src="/assets/screenshot-dashboard.svg" alt="" class="card-surface !p-2 w-full" width="600" height="360" />
        <img src="/assets/screenshot-suppliers.svg" alt="" class="card-surface !p-2 w-full" width="600" height="360" />
      </div>
      <p class="mt-6 text-center text-sm text-ink/50">
        {lang === 'bg' ? 'Платформата в действие — табло и доставчици' : 'Platform in action — dashboard and suppliers'}
      </p>
    </section>
  </SectionReveal>

  <SectionReveal>
    <section class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8">
      <div class="rounded-3xl border border-purple-mid/20 bg-white/60 p-8 text-center backdrop-blur sm:p-12">
        <h2 class="text-2xl font-bold text-purple-deep">{strings.home.regulatoryTitle}</h2>
        <p class="mx-auto mt-4 max-w-2xl text-ink/70">{strings.home.regulatoryDesc}</p>
        <div class="mt-8 flex flex-wrap justify-center gap-4">
          <a href={langPath(lang, '/solutions/eudr')} class="btn-primary">EUDR</a>
          <a href={langPath(lang, '/solutions/ppwr')} class="btn-secondary">
            {lang === 'bg' ? 'Регламент 2025/40' : 'Regulation 2025/40'}
          </a>
        </div>
      </div>
    </section>
  </SectionReveal>

  <section class="mx-auto max-w-7xl px-4 pb-24 sm:px-6 lg:px-8">
    <div class="rounded-3xl bg-phoenix-gradient p-8 text-center text-white shadow-2xl sm:p-14">
      <h2 class="text-3xl font-bold">{strings.home.finalCtaTitle}</h2>
      <p class="mx-auto mt-4 max-w-xl text-white/90">{strings.home.finalCtaDesc}</p>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        <ConsultationCTA lang={lang} variant="primary" class="!bg-white !text-purple-deep hover:!bg-white/90" />
        <a href={langPath(lang, '/contact')} class="rounded-full border-2 border-white/60 px-6 py-3 text-sm font-semibold hover:bg-white/10">
          {strings.cta.contact}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
