---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionReveal from '../../components/SectionReveal.astro';
import SolutionCard from '../../components/SolutionCard.astro';
import ContactCTA from '../../components/ContactCTA.astro';
import AssetImage from '../../components/AssetImage.astro';
import { brandAssets, solutionHeroImages } from '../../i18n/assets';
import { solutionGateway } from '../../i18n/solutions';
import { t, langPath } from '../../i18n/ui';
import type { Lang } from '../../i18n/types';

export function getStaticPaths() {
  return [{ params: { lang: 'bg' } }, { params: { lang: 'en' } }];
}

const lang = Astro.params.lang as Lang;
const strings = t(lang);
const currentPath = Astro.url.pathname;

const pageTitle = lang === 'bg'
  ? 'Nentropy — Съответствие във веригата на доставки'
  : 'Nentropy — Supply chain compliance platform';
const pageDesc = strings.home.heroSubtitle;
---

<BaseLayout lang={lang} title={pageTitle} description={pageDesc} currentPath={currentPath}>
  <section class="section-pad relative overflow-hidden">
    <div class="relative mx-auto grid max-w-7xl items-center gap-14 lg:grid-cols-2 lg:gap-16">
      <div class="max-w-xl">
        <p class="section-label">{strings.tagline}</p>
        <h1 class="mt-4 text-4xl font-bold leading-[1.15] tracking-tight text-purple-deep sm:text-5xl lg:text-[3.25rem]">
          {strings.home.heroTitle}
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-ink/70">{strings.home.heroSubtitle}</p>
        <div class="mt-10 flex flex-wrap gap-3">
          <ContactCTA lang={lang} variant="phoenix" label="demo" />
          <ContactCTA lang={lang} variant="secondary" label="consultation" />
        </div>
      </div>

      <div class="story-panel">
        <p class="mb-6 text-center text-sm font-semibold text-purple-deep lg:text-left">{strings.home.storyTitle}</p>
        <div class="story-compare">
          <figure>
            <div class="art-frame">
              <AssetImage src={brandAssets.talisman.burdened} alt="" width={260} height={260} loading="eager" />
            </div>
            <figcaption>{strings.home.storyBefore}</figcaption>
          </figure>
          <figure class="is-after">
            <div class="art-frame ring-2 ring-phoenix-gold/30">
              <AssetImage src={brandAssets.talisman.calm} alt="" width={260} height={260} loading="eager" />
            </div>
            <figcaption>{strings.home.storyAfter}</figcaption>
          </figure>
        </div>
      </div>
    </div>
  </section>

  <SectionReveal>
    <section id="solutions" class="section-pad mx-auto max-w-7xl border-t border-ink/8">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="section-title">{strings.home.solutionsTitle}</h2>
        <p class="section-lead">{strings.home.solutionsSubtitle}</p>
      </div>
      <div class="mt-14 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {solutionGateway.map((s) => {
          const copy = lang === 'bg' ? s.bg : s.en;
          return (
            <SolutionCard
              lang={lang}
              slug={s.slug}
              title={copy.title}
              short={copy.short}
              heroImage={solutionHeroImages[s.slug]}
            />
          );
        })}
      </div>
    </section>
  </SectionReveal>

  <SectionReveal>
    <section class="section-pad mx-auto max-w-7xl bg-white/60">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="section-title">{strings.home.howTitle}</h2>
      </div>
      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {[
          { n: '01', title: strings.home.step1Title, desc: strings.home.step1Desc },
          { n: '02', title: strings.home.step2Title, desc: strings.home.step2Desc },
          { n: '03', title: strings.home.step3Title, desc: strings.home.step3Desc },
        ].map((step) => (
          <div class="card-surface border-l-4 border-l-phoenix-ember/80 pl-5">
            <span class="text-sm font-bold tabular-nums text-phoenix-ember">{step.n}</span>
            <h3 class="mt-3 text-lg font-bold text-purple-deep">{step.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink/65">{step.desc}</p>
          </div>
        ))}
      </div>
    </section>
  </SectionReveal>

  <SectionReveal>
    <section class="section-pad mx-auto max-w-7xl">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <h2 class="section-title">{strings.home.proofTitle}</h2>
        <p class="mt-3 text-ink/65">{strings.home.proofDesc}</p>
      </div>
      <div class="app-showcase mx-auto max-w-6xl">
        <div class="app-showcase-bar" aria-hidden="true">
          <span class="browser-dot"></span>
          <span class="browser-dot"></span>
          <span class="browser-dot"></span>
          <span class="app-showcase-url">qms.joinnentropy.com</span>
        </div>
        <AssetImage
          src={brandAssets.screenshot}
          alt={lang === 'bg' ? 'Регистър на доставчици в Nentropy' : 'Nentropy supplier register'}
          class="app-showcase-img"
          width={1440}
          height={900}
          loading="lazy"
        />
      </div>
    </section>
  </SectionReveal>

  <SectionReveal>
    <section class="section-pad mx-auto max-w-7xl">
      <div class="grid items-center gap-12 rounded-3xl border border-ink/8 bg-white p-8 sm:p-12 lg:grid-cols-2">
        <div class="art-frame mx-auto max-w-md lg:mx-0">
          <AssetImage src={brandAssets.brochure.chaos} alt="" width={400} height={320} loading="lazy" />
        </div>
        <div>
          <h2 class="section-title text-2xl sm:text-3xl">{strings.home.regulatoryTitle}</h2>
          <p class="mt-4 leading-relaxed text-ink/70">{strings.home.regulatoryDesc}</p>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href={langPath(lang, '/solutions/eudr')} class="btn-primary">EUDR</a>
            <a href={langPath(lang, '/solutions/ppwr')} class="btn-secondary">
              {lang === 'bg' ? 'Регламент 2025/40' : 'Regulation 2025/40'}
            </a>
          </div>
        </div>
      </div>
    </section>
  </SectionReveal>

  <section class="mx-auto max-w-7xl px-4 pb-24 sm:px-6 lg:px-8">
    <div class="rounded-3xl bg-phoenix-gradient px-8 py-14 text-center text-white shadow-lg sm:px-14">
      <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">{strings.home.finalCtaTitle}</h2>
      <p class="mx-auto mt-4 max-w-lg text-base leading-relaxed text-white/90">{strings.home.finalCtaDesc}</p>
      <div class="mt-10 flex flex-wrap justify-center gap-3">
        <ContactCTA lang={lang} label="demo" variant="primary" class="!bg-white !text-purple-deep hover:!bg-white/95" />
        <a
          href={langPath(lang, '/contact')}
          class="inline-flex items-center rounded-full border border-white/50 px-6 py-3 text-sm font-semibold text-white transition hover:bg-white/10"
        >
          {strings.cta.contact}
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
