---
import type { Lang } from '../i18n/types';
import { t, langPath } from '../i18n/ui';
import { swapLangInPath } from '../i18n/paths';
import AssetImage from './AssetImage.astro';
import { getSolutionNav } from '../i18n/nav';

interface Props {
  lang: Lang;
  currentPath?: string;
}

const { lang, currentPath = '' } = Astro.props;
const strings = t(lang);
const solutions = getSolutionNav(lang);
const otherLang = lang === 'bg' ? 'en' : 'bg';
const switchPath = swapLangInPath(currentPath || Astro.url.pathname, lang, otherLang);
---

<header class="sticky top-0 z-50 border-b border-white/50 bg-cream/80 backdrop-blur-xl">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-4 sm:px-6 lg:px-8">
    <a href={langPath(lang, '/')} class="flex items-center gap-2 shrink-0" aria-label={strings.siteName}>
      <AssetImage src="assets/logo.svg" alt="" class="h-8 w-auto" width={140} height={32} />
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main">
      <div class="group relative">
        <button
          type="button"
          class="nav-link flex items-center gap-1 rounded-lg px-3 py-2 hover:bg-white/60"
          aria-haspopup="true"
        >
          {strings.nav.solutions}
          <svg class="h-4 w-4 opacity-60" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
        </button>
        <div class="invisible absolute left-0 top-full z-50 min-w-[280px] rounded-2xl border border-white/80 bg-white/95 p-2 opacity-0 shadow-xl backdrop-blur transition-all group-hover:visible group-hover:opacity-100">
          {solutions.map((item) => (
            <a href={item.href} class="block rounded-xl px-4 py-2.5 text-sm font-medium text-ink hover:bg-purple-deep/5 hover:text-purple-deep">
              {item.label}
            </a>
          ))}
        </div>
      </div>
      <a href={langPath(lang, '/blog')} class="nav-link rounded-lg px-3 py-2 hover:bg-white/60">{strings.nav.blog}</a>
      <a href={langPath(lang, '/events')} class="nav-link rounded-lg px-3 py-2 hover:bg-white/60">{strings.nav.events}</a>
      <a href={langPath(lang, '/docs/integrations')} class="nav-link rounded-lg px-3 py-2 hover:bg-white/60">{strings.nav.docs}</a>
      <a href={langPath(lang, '/about')} class="nav-link rounded-lg px-3 py-2 hover:bg-white/60">{strings.nav.about}</a>
      <a href={langPath(lang, '/contact')} class="nav-link rounded-lg px-3 py-2 hover:bg-white/60">{strings.nav.contact}</a>
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <a href={switchPath} class="hidden text-xs font-semibold uppercase tracking-wide text-steel sm:inline hover:text-purple-deep" hreflang={otherLang}>
        {otherLang}
      </a>
      <a href="https://app.joinnentropy.com/auth" class="hidden text-sm font-medium text-ink/70 sm:inline hover:text-purple-deep">
        {strings.nav.login}
      </a>
      <a href="https://app.joinnentropy.com/auth" class="btn-phoenix hidden text-xs sm:inline-flex sm:text-sm">
        {strings.nav.trial}
      </a>
      <button
        type="button"
        id="mobile-menu-btn"
        class="rounded-lg p-2 text-ink lg:hidden hover:bg-white/60"
        aria-label="Menu"
        aria-expanded="false"
      >
        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="hidden border-t border-white/50 bg-cream/95 px-4 py-4 lg:hidden">
    <p class="mb-2 text-xs font-semibold uppercase tracking-wide text-steel">{strings.nav.solutions}</p>
    {solutions.map((item) => (
      <a href={item.href} class="block py-2 text-sm font-medium">{item.label}</a>
    ))}
    <hr class="my-3 border-white/60" />
    <a href={langPath(lang, '/blog')} class="block py-2 text-sm">{strings.nav.blog}</a>
    <a href={langPath(lang, '/events')} class="block py-2 text-sm">{strings.nav.events}</a>
    <a href={langPath(lang, '/docs/integrations')} class="block py-2 text-sm">{strings.nav.docs}</a>
    <a href={langPath(lang, '/about')} class="block py-2 text-sm">{strings.nav.about}</a>
    <a href={langPath(lang, '/contact')} class="block py-2 text-sm">{strings.nav.contact}</a>
    <a href={switchPath} class="mt-3 block py-2 text-sm font-semibold uppercase">{otherLang}</a>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden') === false;
    btn.setAttribute('aria-expanded', String(open));
  });
</script>
