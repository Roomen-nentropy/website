---
import type { Lang } from '../i18n/types';
import { t, langPath } from '../i18n/ui';
import { brandAssets } from '../i18n/assets';
import { getSolutionNav } from '../i18n/nav';
import AssetImage from './AssetImage.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const strings = t(lang);
const solutions = getSolutionNav(lang);
const year = new Date().getFullYear();
const brochureUrl = 'https://roomen-nentropy.github.io/nentropy_brochure_ifsfocusdays/';
---

<footer class="mt-auto border-t border-ink/8 bg-white">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-10 md:grid-cols-2 lg:grid-cols-4">
      <div>
        <AssetImage src={brandAssets.logoColor} alt={strings.siteName} class="mb-4 h-9 w-auto" />
        <p class="text-sm text-ink/70 leading-relaxed">{strings.tagline}</p>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-purple-deep">{strings.footer.product}</h3>
        <ul class="space-y-2">
          {solutions.map((s) => (
            <li><a href={s.href} class="text-sm text-ink/70 hover:text-purple-deep">{s.label}</a></li>
          ))}
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-purple-deep">{strings.footer.company}</h3>
        <ul class="space-y-2 text-sm text-ink/70">
          <li><a href={langPath(lang, '/about')} class="hover:text-purple-deep">{strings.nav.about}</a></li>
          <li><a href={langPath(lang, '/blog')} class="hover:text-purple-deep">{strings.nav.blog}</a></li>
          <li><a href={langPath(lang, '/events')} class="hover:text-purple-deep">{strings.nav.events}</a></li>
          <li><a href={langPath(lang, '/contact')} class="hover:text-purple-deep">{strings.nav.contact}</a></li>
          <li><a href={brochureUrl} class="hover:text-purple-deep" target="_blank" rel="noopener">{strings.footer.brochure}</a></li>
        </ul>
      </div>
      <div>
        <h3 class="mb-3 text-sm font-semibold text-purple-deep">{strings.footer.legal}</h3>
        <ul class="space-y-2 text-sm text-ink/70">
          <li><a href={langPath(lang, '/privacy')} class="hover:text-purple-deep">{strings.footer.privacy}</a></li>
          <li><a href={langPath(lang, '/terms')} class="hover:text-purple-deep">{strings.footer.terms}</a></li>
          <li><a href={langPath(lang, '/cookies')} class="hover:text-purple-deep">{strings.footer.cookies}</a></li>
          <li><a href={langPath(lang, '/docs/integrations')} class="hover:text-purple-deep">{strings.nav.docs}</a></li>
        </ul>
      </div>
    </div>
    <div class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-ink/10 pt-8 sm:flex-row">
      <p class="text-xs text-ink/50">© {year} Nentropy. {strings.footer.rights}</p>
    </div>
  </div>
</footer>
