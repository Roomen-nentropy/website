---
import type { Lang } from '../i18n/types';
import { langPath, t } from '../i18n/ui';
import AssetImage from './AssetImage.astro';

interface Props {
  lang: Lang;
  slug: string;
  title: string;
  short: string;
  heroImage?: string;
}

const { lang, slug, title, short, heroImage } = Astro.props;
const strings = t(lang);
---

<a href={langPath(lang, `/solutions/${slug}`)} class="card-surface group flex h-full flex-col overflow-hidden !p-0">
  {heroImage && (
    <div class="art-frame !rounded-none !border-0 !border-b !border-ink/8 !bg-gradient-to-b from-purple-deep/[0.03] to-white">
      <AssetImage src={heroImage} alt="" class="max-h-36" width={320} height={180} loading="lazy" />
    </div>
  )}
  <div class="flex flex-1 flex-col p-5">
    <h3 class="text-lg font-bold text-purple-deep transition-colors group-hover:text-phoenix-ember">{title}</h3>
    <p class="mt-2 flex-1 text-sm leading-relaxed text-ink/65">{short}</p>
    <span class="mt-4 text-sm font-semibold text-purple-mid group-hover:text-phoenix-ember">
      {strings.cta.learnMore} →
    </span>
  </div>
</a>
