---
import type { Lang } from '../i18n/types';
import { langPath } from '../i18n/ui';
import { t } from '../i18n/ui';

interface Props {
  lang: Lang;
  slug: string;
  icon: string;
  title: string;
  short: string;
}

const { lang, slug, icon, title, short } = Astro.props;
const strings = t(lang);
---

<a
  href={langPath(lang, `/solutions/${slug}`)}
  class="card-surface group flex flex-col gap-4"
>
  <div class="flex items-start justify-between">
    <span class="text-3xl" aria-hidden="true">{icon}</span>
    <span class="rounded-full bg-phoenix-gold/20 px-2 py-0.5 text-xs font-semibold text-phoenix-ember opacity-0 transition-opacity group-hover:opacity-100">
      →
    </span>
  </div>
  <div>
    <h3 class="text-lg font-bold text-purple-deep group-hover:text-phoenix-ember transition-colors">{title}</h3>
    <p class="mt-2 text-sm text-ink/70 leading-relaxed">{short}</p>
  </div>
  <span class="mt-auto text-sm font-semibold text-purple-mid group-hover:text-phoenix-flame">
    {strings.cta.learnMore}
  </span>
</a>
